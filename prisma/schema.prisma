// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user")
  isBanned  Boolean  @default(false)
  nickname  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
  comments  Comment[]
  beatmaps  Beatmap[]
  scoreRecords ScoreRecord[]
  fanworks     Fanwork[]
  groupActivities GroupActivity[]
  groupJoins     GroupJoin[]
}

model ForumSection {
  id          String   @id
  name        String
  description String
  displayOrder Int

  posts       Post[]
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  section   String    @default("general")
  authorId  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User      @relation(fields: [authorId], references: [id])
  sectionMeta ForumSection @relation(fields: [section], references: [id])
  comments  Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  imageUrl  String?
  postId    Int
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}

model Beatmap {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  difficulty  String
  gameType    String
  fileUrl     String
  uploaderId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uploader    User     @relation(fields: [uploaderId], references: [id])
}

model ScoreRecord {
  id        Int      @id @default(autoincrement())
  game      String
  songTitle String
  difficulty String
  result    String
  rank      String
  comment   String?
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Fanwork {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  authorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
  images      FanworkImage[]
  tags        FanworkTag[]
}

model FanworkImage {
  id         Int      @id @default(autoincrement())
  fanworkId  Int
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  fanwork    Fanwork  @relation(fields: [fanworkId], references: [id], onDelete: Cascade)

  @@index([fanworkId, sortOrder])
}

model FanworkTag {
  id         Int      @id @default(autoincrement())
  fanworkId  Int
  name       String
  createdAt  DateTime @default(now())

  fanwork    Fanwork  @relation(fields: [fanworkId], references: [id], onDelete: Cascade)

  @@unique([fanworkId, name])
  @@index([name])
}

model GroupActivity {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  stock       Int
  deadline    DateTime?
  status      String
  organizerId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer   User     @relation(fields: [organizerId], references: [id])
  images      GroupActivityImage[]
  joins       GroupJoin[]
}

model GroupActivityImage {
  id         Int      @id @default(autoincrement())
  groupId    Int
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  group      GroupActivity @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, sortOrder])
}

model GroupJoin {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  quantity  Int      @default(1)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group     GroupActivity @relation(fields: [groupId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}
